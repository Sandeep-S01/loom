# Environment Variables Template
# Copy to .env and fill in values

# ─── Database ───────────────────────────────
DATABASE_URL=postgresql://clm:clm_dev_password@localhost:5432/clm_tool
REDIS_URL=redis://localhost:6379

# ─── Session ────────────────────────────────
SESSION_SECRET=change-me-to-a-random-64-char-string

# ─── Single User (V1) ──────────────────────
DEFAULT_USER_EMAIL=user@clm.local
DEFAULT_USER_PASSWORD=change-me

# ─── Provider Keys (backend only) ──────────
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ─── Encryption ─────────────────────────────
# Used to encrypt provider keys at rest in DB
PROVIDER_KEY_ENCRYPTION_SECRET=change-me-to-a-random-32-byte-hex

# ─── Companion ──────────────────────────────
COMPANION_PAIRING_SECRET=change-me-to-a-random-32-char-string

# ─── App ────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001
