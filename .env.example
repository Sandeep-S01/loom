# Environment Variables Template
# Copy to .env and fill in values

# ─── Database ───────────────────────────────
DATABASE_URL=postgresql://clm:clm_dev_password@localhost:5432/clm_tool
REDIS_URL=redis://localhost:6379
DATABASE_CONNECT_TIMEOUT_SECONDS=5
REDIS_CONNECT_TIMEOUT_MS=3000
READINESS_PROBE_TIMEOUT_MS=3000

# ─── Session ────────────────────────────────
BROWSER_SESSION_TTL_HOURS=168
ALLOW_DEV_SESSION=false

# ─── Single User (V1) ──────────────────────
DEFAULT_USER_EMAIL=user@clm.local
DEFAULT_USER_PASSWORD=change-me

# ─── Provider Keys (backend only) ──────────
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ─── Encryption ─────────────────────────────
# Used to encrypt provider keys at rest in DB
PROVIDER_KEY_ENCRYPTION_SECRET=change-me-to-a-random-32-byte-hex

# ─── Companion ──────────────────────────────
COMPANION_PAIRING_SECRET=change-me-to-a-random-32-char-string

# ─── App ────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=
BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=
# Enabled by the web container build; keep false for local Windows builds.
NEXT_STANDALONE_OUTPUT=false

# Provider request and chat load controls
PROVIDER_REQUEST_TIMEOUT_MS=60000
PROVIDER_MAX_ATTEMPTS=2
AI_MAX_CONCURRENT_REQUESTS=10
AI_MAX_CONCURRENT_REQUESTS_PER_CONVERSATION=2
AI_CHAT_REQUESTS_PER_MINUTE=30
AI_MAX_HISTORY_MESSAGES=40
AI_MAX_USER_MESSAGE_CHARS=20000
AI_CHAT_REQUEST_DEADLINE_MS=90000
API_BODY_LIMIT_BYTES=26214400
LOG_LEVEL=info
METRICS_ENABLED=false
METRICS_TOKEN=

# Bounded raw telemetry/session cleanup (6 hours by default)
RETENTION_CLEANUP_ON_STARTUP=true
RETENTION_CLEANUP_INTERVAL_MS=21600000
RETENTION_CLEANUP_BATCH_SIZE=1000
MODEL_USAGE_RETENTION_DAYS=30
PROVIDER_ATTEMPT_RETENTION_DAYS=30
AUDIT_EVENT_RETENTION_DAYS=90
EXPIRED_SESSION_GRACE_DAYS=7
EXPIRED_IDEMPOTENCY_GRACE_DAYS=1

# Free-model catalog synchronization
FREE_MARKETPLACE_SYNC_ON_STARTUP=false
FREE_MARKETPLACE_SYNC_INTERVAL_MS=0
