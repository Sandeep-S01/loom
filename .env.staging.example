# Copy to .env.staging and replace every CHANGE_ME value.
POSTGRES_USER=loom
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=loom
DATABASE_URL=postgresql://loom:CHANGE_ME_URL_ENCODED_DATABASE_PASSWORD@postgres:5432/loom

REDIS_PASSWORD=CHANGE_ME_RANDOM_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_URL_ENCODED_REDIS_PASSWORD@redis:6379

PUBLIC_WEB_URL=http://localhost:8080
WEB_HOST_PORT=8080
BACKEND_HOST_PORT=3001
PROMETHEUS_HOST_PORT=9090

DEFAULT_USER_EMAIL=admin@example.com
DEFAULT_USER_PASSWORD=CHANGE_ME_RANDOM_ADMIN_PASSWORD
PROVIDER_KEY_ENCRYPTION_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
COMPANION_PAIRING_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
METRICS_TOKEN=CHANGE_ME_AT_LEAST_32_ALPHANUMERIC_CHARACTERS

OPENROUTER_API_KEY=
GEMINI_API_KEY=
BACKEND_IMAGE=loom-backend:staging
WEB_IMAGE=loom-web:staging
LOG_LEVEL=info
