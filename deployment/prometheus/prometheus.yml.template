global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: loom-backend
    metrics_path: /metrics
    authorization:
      type: Bearer
      credentials: "__METRICS_TOKEN__"
    static_configs:
      - targets: ["backend:3001"]
